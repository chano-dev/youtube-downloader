{
    "manifest_version": 3,
    "name": "YT Downloader",
    "version": "1.0.0",
    "description": "Download YouTube videos and audio in multiple qualities. Requires local server running.",
    "author": "Charles Nuno",

    "permissions": [
        "activeTab",
        "storage",
        "tabs"
    ],

    "host_permissions": [
        "http://localhost:3000/*"
    ],

    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon-16.png",
            "48": "icons/icon-48.png",
            "128": "icons/icon-128.png"
        }
    },

    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    }
}